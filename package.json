    "check": "node --check src/worker.js && node --check public/eei-engine.js"
  },
  "dependencies": {
    "three": "0.165.0"
  },
  "devDependencies": {
    "http-server": "14.1.1",
    "wrangler": "3.114.15"
  }
}
