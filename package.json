{
  "name": "enterprise-experience-injector",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Enterprise Experience Injector: Cloudflare Worker injected Three.js overlay for internal SPAs.",
  "scripts": {
    "postinstall": "node scripts/copy-three.mjs",
    "dev": "wrangler dev",
